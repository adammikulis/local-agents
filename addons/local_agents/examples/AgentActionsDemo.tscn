[node name="Subtitle" type="Label" parent="Margin/VBox"]
layout_mode = 2
autowrap_mode = 3
text = "The model's reply becomes game actions (set_color, pulse). The manual buttons fire the exact same actions, so the loop is visible with no model."

[node name="StatusLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 3
