# Large third-party asset packs — keep locally, never commit
/Kenney Game Assets All-in-1 3.5.0.zip
Kenney*.zip

# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
*.import
*.uid

# ...but DO track 3D-model import sidecars so glTF/GLB loads resolve on a fresh checkout.
!addons/local_agents/assets/models/**/*.import

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Project-specific ignores
AGENTS.md
android/
.vs
.vscode/
.releases
